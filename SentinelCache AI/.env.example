# ============================================================
# .env.example  —  Copy this file and rename it to .env
# NEVER commit the real .env file to GitHub.
# These are localhost URLs for your local Docker databases.
# ============================================================

# ── PostgreSQL (Main Database) ──────────────────────────────
POSTGRES_URL=postgresql://cyberuser:cyberpass123@localhost:5432/Cache_db

# ── Redis (L2 Cache) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MongoDB (L3 Cache) ──────────────────────────────────────
MONGO_URL=mongodb://cyberuser:cyberpass123@localhost:27017/Cache_db?authSource=admin

# ── Cache Settings ──────────────────────────────────────────
CACHE_TTL_REDIS_SECONDS=3600        # Redis entries expire after 1 hour
CACHE_TTL_MONGO_HOURS=24            # MongoDB entries expire after 24 hours
L1_MAX_SIZE=500                      # Max number of entries in Python dict cache

# ── App Settings ────────────────────────────────────────────
APP_SECRET_KEY=change-this-to-a-random-string-in-production
MODEL_VERSION=rf-url-v2.1
DEBUG=true